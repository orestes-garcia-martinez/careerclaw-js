# .env.example
#
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit your actual secrets.
#
#   cp .env.example .env
#   # then edit .env with your values
#
# Usage (Node 20+, no dotenv library required):
#   node --env-file=.env dist/cli.js
#   npx tsx --env-file=.env src/cli.ts   (development)
#   CAREERCLAW_LLM_KEY=sk-... npx tsx src/cli.ts   (inline override)


# ──────────────────────────────────────────────────────────────────────────────
# OpenClaw Gateway (Agent Layer)
# ──────────────────────────────────────────────────────────────────────────────
#
# Required when running CareerClaw as an OpenClaw/ClawHub skill.
# Not required for standalone CLI usage.

# Generated by the OpenClaw docker-setup.sh script.
OPENCLAW_GATEWAY_TOKEN=

# Telegram bot token (from @BotFather). Required for Telegram delivery.
TELEGRAM_BOT_TOKEN=


# ──────────────────────────────────────────────────────────────────────────────
# Agent LLM Provider Keys (OpenClaw Model Layer)
# ──────────────────────────────────────────────────────────────────────────────
#
# These keys power the OpenClaw agent itself (routing, orchestration).
# Separate from the CareerClaw draft enhancement keys below.
# Provide at least ONE.

# Primary (recommended)
OPENAI_API_KEY=sk-proj-...

# Optional fallback
ANTHROPIC_API_KEY=sk-ant-...


# ──────────────────────────────────────────────────────────────────────────────
# CareerClaw Pro License
# ──────────────────────────────────────────────────────────────────────────────
#
# One-time lifetime license key.
# Purchase: https://polar.sh/orestes-garcia-martinez/products/careerclaw-pro
# Leave blank to run in Free tier (deterministic drafts, no gap analysis,
# no resume intelligence).
CAREERCLAW_PRO_KEY=


# ──────────────────────────────────────────────────────────────────────────────
# CareerClaw Pro — LLM Draft Enhancement (Draft Layer)
# ──────────────────────────────────────────────────────────────────────────────
#
# Controls Pro-only LLM-enhanced outreach drafts.
# Separate from the OpenClaw agent keys above.
#
# Enhancement only runs when ALL of the following are true:
#   - CAREERCLAW_PRO_KEY is valid
#   - An LLM key is available (see below)
#   - Resume intelligence is present (.careerclaw/resume.txt or resume.pdf)
#
# Provider-specific keys (recommended — allows independent failover chains):

# Anthropic key for draft enhancement
# Get yours at: https://console.anthropic.com/settings/keys
CAREERCLAW_ANTHROPIC_KEY=

# OpenAI key for draft enhancement
# Get yours at: https://platform.openai.com/api-keys
CAREERCLAW_OPENAI_KEY=

# Legacy single-key fallback (not recommended for mixed chains).
# Used only when the provider-specific key above is absent.
CAREERCLAW_LLM_KEY=


# ──────────────────────────────────────────────────────────────────────────────
# Draft Enhancement — Failover Configuration
# ──────────────────────────────────────────────────────────────────────────────
#
# Provider/model chain — tried left to right on failure (order matters).
# Each entry is provider/model. Leave blank to use the built-in default.
#
# Default: anthropic/claude-haiku-4-5-20251001,openai/gpt-4o-mini
#
# Example with extended chain:
#   anthropic/claude-haiku-4-5-20251001,openai/gpt-4o-mini,anthropic/claude-sonnet-4-6
CAREERCLAW_LLM_CHAIN=

# Maximum retries per candidate in the chain before moving to the next (default: 2)
CAREERCLAW_LLM_MAX_RETRIES=2

# Consecutive failures per run before the circuit breaker opens (default: 2)
CAREERCLAW_LLM_CIRCUIT_BREAKER_FAILS=2


# ──────────────────────────────────────────────────────────────────────────────
# Job Sources
# ──────────────────────────────────────────────────────────────────────────────
#
# Hacker News "Who is Hiring?" thread ID.
# HN posts a new thread on the first weekday of each month.
# The value in src/config.ts is updated each release — only override here
# if you need to test against a specific historical thread.
# Find it: search HN for "Ask HN: Who is hiring?" and copy the item ID.
HN_WHO_IS_HIRING_ID=47219668


# ──────────────────────────────────────────────────────────────────────────────
# Runtime Directory Override (optional)
# ──────────────────────────────────────────────────────────────────────────────
#
# Defaults to ~/.careerclaw
# Only set this to run multiple isolated CareerClaw environments on the same
# machine, or to point at a custom storage location.
CAREERCLAW_DIR=
